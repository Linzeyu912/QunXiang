# Allowed CORS origins, multiple separated by comma
ALLOWED_ORIGINS=http://localhost:5173,https://staging.example.com

# =============================================================================
# LLM Provider Configuration
# Choose ONE of the options below:
# =============================================================================

# -----------------------------------------------------------------------------
# Option A: Custom API (OpenAI-compatible) — 推荐
# 支持 OpenAI / DeepSeek / MiniMax 等任何 OpenAI 兼容接口。
# 接口地址填到 /v1 即可，后端自动补全 /chat/completions。
# 常见服务商示例：
#   DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1   LLM_MODEL=deepseek-chat
#   MiniMax:   LLM_BASE_URL=https://api.minimaxi.com/v1   LLM_MODEL=MiniMax-M2
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1     LLM_MODEL=gpt-4o-mini
# 多 key 并发：用逗号分隔多个 key 以轮询使用、提升并发额度。
# -----------------------------------------------------------------------------
LLM_PROVIDER=custom
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# LLM_API_KEYS=sk-key1,sk-key2,sk-key3

# -----------------------------------------------------------------------------
# Option B: Mock Data (development/testing only)
# 内置假数据，不需要 API Key，仅用于部署冒烟测试。
# -----------------------------------------------------------------------------
# LLM_MOCK_ENABLED=true
