# Allowed CORS origins, multiple separated by comma
ALLOWED_ORIGINS=http://localhost:5173,https://staging.example.com

# =============================================================================
# LLM Provider Configuration
# Choose ONE of the options below:
# =============================================================================

# -----------------------------------------------------------------------------
# Option A: Ollama (local, no API key required)
# 1. Download: https://ollama.com/download
# 2. Pull model: ollama pull llama3.2
# 3. Start server: ollama serve
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Option B: Custom API (OpenAI-compatible)
# Supports OpenAI, Claude (via API), MiniMax, or any OpenAI-compatible API
# -----------------------------------------------------------------------------
# LLM_PROVIDER=custom
# LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Option C: Mock Data (development/testing only)
# Returns hardcoded Journey to the West characters
# -----------------------------------------------------------------------------
# LLM_MOCK_ENABLED=true
