# Dependencies
node_modules/
.pnpm/

# Build outputs
dist/
build/
*.tsbuildinfo

# 不要把各包 src 下的 tsc 编译产物提交进来
# （各包 main 指向 src 源码、走 tsx 即时编译，无需 .js/.d.ts/.map）
**/src/**/*.js
**/src/**/*.d.ts
**/src/**/*.js.map
**/src/**/*.d.ts.map

# Logs
*.log
pnpm-debug.log*
logs/

# Database
*.db
*.db-journal
prisma/dev.db
prisma/dev.db-journal
*.db.bak*

# Environment files
.env
.env.local
.env.*.local
api.env
!.env.example

# Encrypted config (contains API keys)
.novel-agent-config.encrypted

# Claude Code
.claude/
.codebuddy/
.omc/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Test/Debug files
test_*.bat
test_*.mjs
startup_log*.txt
test_results.txt
test/

# Uploads and runtime data
storage/uploads/
storage/dispatcher.log

# Pipeline run output (contains verbatim excerpts of source novels — never commit)
output/

# Intermediate prescan output (backend-only, not user-facing)
.intermediate/


# IDE session files
.zcode/
